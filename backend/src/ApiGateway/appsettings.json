{
  "JwtSettings": {
    "SecretKey": "PizzaAppSuperSecretKey2024_DoNotShare!",
    "Issuer": "PizzaApp",
    "Audience": "PizzaAppUsers",
    "ExpiresInDays": 7
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-1": { "Address": "http://localhost:5001/" }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
