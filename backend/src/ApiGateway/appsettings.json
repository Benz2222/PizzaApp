{
  "JwtSettings": {
    "SecretKey": "PizzaAppSuperSecretKey2024_DoNotShare!",
    "Issuer": "PizzaApp",
    "Audience": "PizzaAppUsers",
    "ExpiresInDays": 7
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "category-route": {
        "ClusterId": "category-cluster",
        "Match": { "Path": "/api/category/{**catch-all}" }
      },
      "product-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/api/products/{**catch-all}" }
      },
      "cart-route": {
        "ClusterId": "cart-cluster",
        "Match": { "Path": "/api/cart/{**catch-all}" }
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": { "Path": "/api/orders/{**catch-all}" }
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "Match": { "Path": "/api/payment/{**catch-all}" }
      },
      "uploads-route": {
        "ClusterId": "product-cluster",
        "Match": { "Path": "/uploads/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-1": { "Address": "http://localhost:5001/" }
        }
      },
      "category-cluster": {
        "Destinations": {
          "category-1": { "Address": "http://localhost:5003/" }
        }
      },
      "product-cluster": {
        "Destinations": {
          "product-1": { "Address": "http://localhost:5002/" }
        }
      },
      "cart-cluster": {
        "Destinations": {
          "cart-1": { "Address": "http://localhost:5004/" }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order-1": { "Address": "http://localhost:5005/" }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "payment-1": { "Address": "http://localhost:5006/" }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
